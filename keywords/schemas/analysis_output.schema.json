{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://muhfweeceevee.local/keywords/analysis_output.schema.json",
  "title": "CV Keyword Analysis Output",
  "type": "object",
  "required": ["generated_at", "scores", "weighted_keywords", "actions", "integration_hooks"],
  "properties": {
    "generated_at": { "type": "string" },
    "input_summary": {
      "type": "object",
      "properties": {
        "jd_documents": { "type": "integer" },
        "avg_jd_term_count": { "type": "number" },
        "cv_sections": { "type": "array", "items": { "type": "string" } },
        "config_weighted_keywords": { "type": "integer" },
        "duplicate_docs_detected": { "type": "integer" },
        "role_cluster": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scores": {
      "type": "object",
      "required": ["coverage_score", "confidence"],
      "properties": {
        "coverage_score": { "type": "number" },
        "confidence": { "type": "number" }
      },
      "additionalProperties": false
    },
    "weighted_keywords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["keyword", "final_weight", "coverage", "gap_severity"],
        "properties": {
          "keyword": { "type": "string" },
          "normalized_keyword": { "type": "string" },
          "category": { "type": "string" },
          "category_confidence": { "type": "number" },
          "jd_doc_freq": { "type": "integer" },
          "jd_term_freq": { "type": "integer" },
          "tfidf_weight": { "type": "number" },
          "role_prior": { "type": "number" },
          "final_weight": { "type": "number" },
          "cv_hits_total": { "type": "integer" },
          "cv_negated_hits": { "type": "integer" },
          "cv_section_hits": { "type": "object", "additionalProperties": { "type": "integer" } },
          "cv_weighted_hits": { "type": "number" },
          "evidence_hits": { "type": "integer" },
          "evidence_multiplier": { "type": "number" },
          "coverage": { "type": "number" },
          "confidence": { "type": "number" },
          "gap_severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "none"] }
        },
        "additionalProperties": false
      }
    },
    "seniority_intent": { "type": "object", "additionalProperties": true },
    "category_analytics": { "type": "object", "additionalProperties": true },
    "actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "integration_hooks": {
      "type": "object",
      "properties": {
        "editor_panel": {
          "type": "object",
          "required": ["version", "coverage_score", "confidence", "top_keywords", "gaps"],
          "properties": {
            "version": { "type": "string" },
            "coverage_score": { "type": "number" },
            "confidence": { "type": "number" },
            "top_keywords": { "type": "array" },
            "gaps": { "type": "array" },
            "category_analytics": { "type": "object" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "scoring_model": { "type": "object", "additionalProperties": true },
    "schemas": {
      "type": "object",
      "properties": {
        "input": { "type": "string" },
        "output": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
