[Unit]
Description=MuhFweeCeeVee Web (Next.js)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/git-public/MuhFweeCeeVee-Professional CV Template Generator
ExecStart=/usr/bin/env npm run dev --workspace @muhfweeceevee/web
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=development

[Install]
WantedBy=default.target
